{
  "opencollection": "1.0.0",
  "info": {
    "name": "Cigna Provider Access API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "client_credentials",
      "accessTokenUrl": "https://r-hi2.cigna.com/mga/sps/oauth/oauth20/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Patient",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Retrieve the FHIR capability statement",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://fhir.cigna.com/ProviderAccess/v1/metadata"
          },
          "docs": "Retrieve the FHIR capability statement"
        },
        {
          "info": {
            "name": "Retrieve a complete clinical record for an attributed member",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://fhir.cigna.com/ProviderAccess/v1/Patient/:patientId/$everything",
            "params": [
              {
                "name": "patientId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve a complete clinical record for an attributed member"
        }
      ]
    },
    {
      "info": {
        "name": "Bulk Data",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Initiate a bulk data export for a panel of attributed members",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://fhir.cigna.com/ProviderAccess/v1/Group/:groupId/$export",
            "params": [
              {
                "name": "groupId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Initiate a bulk data export for a panel of attributed members"
        }
      ]
    }
  ],
  "bundled": true
}